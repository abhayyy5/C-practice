#include <string>

using namespace std;
void factorialLoop() {
    int n, f = 1;
    cout << "Enter number: ";
    cin >> n;
    for (int i = 1; i <= n; i++)
        f *= i;
    cout << f << endl;
}

// 8. Prime Number
#include <iostream>
#include <string>

using namespace std;
void checkPrime() {
    int n, count = 0;
    cout << "Enter number: ";
    cin >> n;
    for (int i = 1; i <= n; i++)
        if (n % i == 0)
            count++;
    if (count == 2)
        cout << "Prime" << endl;
    else
        cout << "Not Prime" << endl;
}

// 9. Reverse Number
#include <iostream>
#include <string>

using namespace std;
void reverseNumber() {
    int n, rev = 0, r;
    cout << "Enter number: ";
    cin >> n;
    while (n > 0) {
        r = n % 10;
        rev = rev * 10 + r;
        n /= 10;
    }
    cout << rev << endl;
}

// 10. Sum of Digits
#include <iostream>
#include <string>

using namespace std;
void sumOfDigits() {
    int n, sum = 0;
    cout << "Enter number: ";
    cin >> n;
    while (n > 0) {
        sum += n % 10;
        n /= 10;
    }
    cout << sum << endl;
}

// 11. Largest Element in Array
#include <iostream>
#include <string>

using namespace std;
void largestElement() {
    int arr[5], max;
    cout << "Enter 5 elements: ";
    for (int i = 0; i < 5; i++)
        cin >> arr[i];
    max = arr[0];
    for (int i = 1; i < 5; i++)
        if (arr[i] > max)
            max = arr[i];
    cout << max << endl;
}

