// 18. Palindrome Number
#include <iostream>
#include <string>

using namespace std;
void palindrome() {
    int n, rev = 0, temp, r;
    cout << "Enter number: ";
    cin >> n;
    temp = n;
    while (n > 0) {
        r = n % 10;
        rev = rev * 10 + r;
        n /= 10;
    }
    if (temp == rev)
        cout << "Palindrome" << endl;
    else
        cout << "Not Palindrome" << endl;
}

