// 2. Add Two Numbers
#include <iostream>
using namespace std;

int main() {
    int a, b;
    cin >> a >> b;
    cout << "Sum = " << a + b;
    return 0;
}

// 3. Swap Two Numbers
#include <iostream>
using namespace std;

int main() {
    int a, b, temp;
    cin >> a >> b;

    temp = a;
    a = b;
    b = temp;

    cout << "a = " << a << " b = " << b;
    return 0;
}

//4. Even or Odd
#include <iostream>
using namespace std;

int main() {
    int n;
    cin >> n;

    if (n % 2 == 0)
        cout << "Even";
    else
        cout << "Odd";

    return 0;
}

//5. Largest of Three Numbers
#include <iostream>
using namespace std;

int main() {
    int a, b, c;
    cin >> a >> b >> c;

    if (a > b && a > c)
        cout << a;
    else if (b > c)
        cout << b;
    else
        cout << c;

    return 0;
}
