// 58. Sort array (Ascending - Bubble Sort logic)
#include <iostream>
using namespace std;
void sortArray() {
    int a[5], temp;
    cout << "Enter 5 elements to sort: ";
    for (int i = 0; i < 5; i++) cin >> a[i];
    for (int i = 0; i < 5; i++) {
        for (int j = i + 1; j < 5; j++) {
            if (a[i] > a[j]) {
                temp = a[i];
                a[i] = a[j];
                a[j] = temp;
            }
        }
    }
    cout << "Sorted: ";
    for (int i = 0; i < 5; i++) cout << a[i] << " ";
    cout << endl;
}

// 59. Second largest element
#include <iostream>
using namespace std;
void secondLargest() {
    int a[5], max = 0, second = 0;
    cout << "Enter 5 elements: ";
    for (int i = 0; i < 5; i++) cin >> a[i];
    for (int i = 0; i < 5; i++) {
        if (a[i] > max) {
            second = max;
            max = a[i];
        } else if (a[i] > second && a[i] != max) {
            second = a[i];
        }
    }
    cout << "Second Largest = " << second << endl;
}

