// 80. Remove duplicates
#include <iostream>
using namespace std;
void removeDuplicates() {
    int a[5], n = 5;
    for (int i = 0; i < 5; i++) cin >> a[i];
    for (int i = 0; i < n; i++) {
        for (int j = i + 1; j < n; j++) {
            if (a[i] == a[j]) {
                for (int k = j; k < n - 1; k++) {
                    a[k] = a[k + 1];
                }
                n--;
                j--;
            }
        }
    }
    for (int i = 0; i < n; i++) cout << a[i] << " ";
}

