// 49. Recursive Factorial
#include <iostream>
#include <string>

using namespace std;
int factorial(int x) {
    if (x == 0) return 1;
    return x * factorial(x - 1);
}

// 50. Sum of Digits (Recursion)
#include <iostream>
#include <string>

using namespace std;
int sumDigitsRec(int x) {
    if (x == 0) return 0;
    return x % 10 + sumDigitsRec(x / 10);
}

