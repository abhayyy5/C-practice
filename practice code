// 8. Prime Number
#include <iostream>
#include <string>

using namespace std;
void checkPrime() {
    int n, count = 0;
    cout << "Enter number: ";
    cin >> n;
    for (int i = 1; i <= n; i++)
        if (n % i == 0)
            count++;
    if (count == 2)
        cout << "Prime" << endl;
    else
        cout << "Not Prime" << endl;
}

// 9. Reverse Number
#include <iostream>
#include <string>

using namespace std;
void reverseNumber() {
    int n, rev = 0, r;
    cout << "Enter number: ";
    cin >> n;
    while (n > 0) {
        r = n % 10;
        rev = rev * 10 + r;
        n /= 10;
    }
    cout << rev << endl;
}

