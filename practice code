// 68. Diamond pattern
#include <iostream>
using namespace std;
void diamondPattern() {
    // Upper part
    for (int i = 1; i <= 5; i++) {
        for (int j = 1; j <= 5 - i; j++) cout << " ";
        for (int k = 1; k <= 2 * i - 1; k++) cout << "*";
        cout << endl;
    }
    // Lower part
    for (int i = 4; i >= 1; i--) {
        for (int j = 1; j <= 5 - i; j++) cout << " ";
        for (int k = 1; k <= 2 * i - 1; k++) cout << "*";
        cout << endl;
    }
}

