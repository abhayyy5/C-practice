}

// 9. Reverse Number
#include <iostream>
#include <string>

using namespace std;
void reverseNumber() {
    int n, rev = 0, r;
    cout << "Enter number: ";
    cin >> n;
    while (n > 0) {
        r = n % 10;
        rev = rev * 10 + r;
        n /= 10;
    }
    cout << rev << endl;
}

